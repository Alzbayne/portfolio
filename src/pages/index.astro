---
import PageLayout from '../layouts/BaseLayout.astro'
import Section from '../components/Section.astro'
import Card from '../components/Card.astro'
import ProjectCard from '../components/ProjectCard.astro'
import Label from '../components/Label.astro'
import SkillLayout from '../components/SkillLayout.astro'

import { Image } from 'astro:assets'
import astro from '../assets/profile-picture.png'

const gameDevSkills = ['Unreal Engine', 'Blueprints', 'C++', 'Animation State Machines', 'Gameplay Systems', 'Character Controllers', 'Combat Design'];
const softwareDevSkills = ['Python', 'TypeScript', 'C#', 'Docker', 'FastAPI', 'SQL'];
const languages = ['Python', 'Java', 'C', 'C++', 'C#', 'JavaScript', 'TypeScript'];
const webTech = ['Hono', 'grammY', 'Tailwind CSS', 'Bootstrap', 'Flask', 'FastAPI', 'Next.js', 'Django', 'Gradio', 'Streamlit'];
const mlTech = ['Transformers', 'Scikit-learn', 'PyTorch', 'TensorFlow', 'Pandas', 'NumPy'];
const devTools = ['Docker', 'Git', 'MySQL', 'PowerBI', 'Qdrant', 'Redis', 'VS Code', 'GitHub Copilot', 'Cloudflare KV', 'Cloudflare Workers', 'Vercel', 'n8n'];

const crypto_web3 = ['grammY', 'Hono', 'Cloudflare Workers', 'Helius API', 'Cloudflare KV'];
const barkley = ['Python', 'PyTorch', 'Transformers', 'Streamlit', 'Redis'];
const snapfolia = ['Python', 'PyTorch', 'Transformers'];
const semanticlip = ['Python', 'Gradio', 'Transformers', 'Qdrant'];
const citizenRegistry = ['Java', 'Eclipse IDE', 'MySQL', 'Javax'];
const alamat = ['C++', 'Console', 'File I/O', 'Data Structures', 'OOP'];

---

<PageLayout meta={{ title: 'Home' }}>
	<div class='flex w-full flex-col gap-y-10'>
		<section class='flex flex-col items-center gap-y-7'>
			<Image
				src={astro}
				alt='profile photo'
				class='h-40 w-auto rounded-full p-2'
				loading='lazy'
			/>

			<div class='flex flex-col items-center gap-y-4'>
				<h1 class='text-center text-3xl font-bold'>Prince Daniel Mampusti</h1>
				<div class='flex flex-wrap justify-center gap-x-7 gap-y-3'>
					<Label 
						title='+63 920-5406-696'
						as = 'a'
						href='tel:639205406696'>
						<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16' class='h-5 w-5' slot='icon'>
							<path
								fill='currentColor'
								d='M14.67 11.28v2a1.33 1.33 0 0 1-1.45 1.33 13.19 13.19 0 0 1-5.75-2.05 13 13 0 0 1-4-4 13.19 13.19 0 0 1-2.05-5.78A1.33 1.33 0 0 1 2.74 1.33h2a1.33 1.33 0 0 1 1.33 1.15 8.56 8.56 0 0 0 .47 1.87 1.33 1.33 0 0 1-.3 1.41L5.39 6.61a10.67 10.67 0 0 0 4 4l.85-.85a1.33 1.33 0 0 1 1.41-.3 8.56 8.56 0 0 0 1.87 .47 1.33 1.33 0 0 1 1.15 1.35z'
							/>
						</svg>
					</Label>
					<Label title='Philippines'>
						<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" slot='icon' class='h-5 w-5 text-foreground/75'>
							<path fill="currentColor" d="M8.75 10a3.25 3.25 0 1 1 6.5 0a3.25 3.25 0 0 1-6.5 0" />
							<path fill="currentColor" fill-rule="evenodd" d="M3.774 8.877a8.04 8.04 0 0 1 8.01-7.377h.432a8.04 8.04 0 0 1 8.01 7.377a8.7 8.7 0 0 1-1.933 6.217L13.5 20.956a1.937 1.937 0 0 1-3 0l-4.792-5.862a8.7 8.7 0 0 1-1.934-6.217M12 5.25a4.75 4.75 0 1 0 0 9.5a4.75 4.75 0 0 0 0-9.5" clip-rule="evenodd" />
						</svg>
					</Label>
					<Label
						title='alyzbane'
						as='a'
						href='https://www.github.com/alyzbane'
						target='_blank'
					>
						<svg 
							xmlns='http://www.w3.org/2000/svg'
							viewBox='0 0 16 16'
							slot='icon'
							class='h-5 w-5 text-foreground/75'
						>
							<path
								fill='currentColor'
								d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"
							/>
						</svg>
					</Label>
					<Label
						title='pdmampusti'
						as='a'
						href='https://www.linkedin.com/in/pdmampusti'
						target='_blank'
					>
						<svg
							xmlns='http://www.w3.org/2000/svg' viewBox='0 0 16 16' slot='icon' class='h-5 w-5 text-foreground/75'
							><path
								fill='currentColor'
								d='M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248c-.015-.709-.52-1.248-1.342-1.248S2.4 3.226 2.4 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586c.173-.431.568-.878 1.232-.878c.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252c-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z'
							/>
						</svg>
					</Label>
					<Label
						title='gamedev'
						as='a'
						href='https://alyzbane.itch.io'
						target='_blank'
					>
						<svg
							xmlns="http://www.w3.org/2000/svg"
							viewBox="0 0 245.37069 220.73612"
							slot="icon"
							class="h-5 w-5 text-foreground/75"
							fill="currentColor"
						>
							<path
								d="M31.99 1.365C21.287 7.72.2 31.945 0 38.298v10.516C0 62.144 12.46 73.86 23.773 73.86c13.584 0 24.902-11.258 24.903-24.62 0 13.362 10.93 24.62 24.515 24.62 13.586 0 24.165-11.258 24.165-24.62 0 13.362 11.622 24.62 25.207 24.62h.246c13.586 0 25.208-11.258 25.208-24.62 0 13.362 10.58 24.62 24.164 24.62 13.585 0 24.515-11.258 24.515-24.62 0 13.362 11.32 24.62 24.903 24.62 11.313 0 23.773-11.714 23.773-25.046V38.298c-.2-6.354-21.287-30.58-31.988-36.933C180.118.197 157.056-.005 122.685 0c-34.37.003-81.228.54-90.697 1.365zm65.194 66.217a28.025 28.025 0 0 1-4.78 6.155c-5.128 5.014-12.157 8.122-19.906 8.122a28.482 28.482 0 0 1-19.948-8.126c-1.858-1.82-3.27-3.766-4.563-6.032l-.006.004c-1.292 2.27-3.092 4.215-4.954 6.037a28.5 28.5 0 0 1-19.948 8.12c-.934 0-1.906-.258-2.692-.528-1.092 11.372-1.553 22.24-1.716 30.164l-.002.045c-.02 4.024-.04 7.333-.06 11.93.21 23.86-2.363 77.334 10.52 90.473 19.964 4.655 56.7 6.775 93.555 6.788h.006c36.854-.013 73.59-2.133 93.554-6.788 12.883-13.14 10.31-66.614 10.52-90.474-.022-4.596-.04-7.905-.06-11.93l-.003-.045c-.162-7.926-.623-18.793-1.715-30.165-.786.27-1.757.528-2.692.528a28.5 28.5 0 0 1-19.948-8.12c-1.862-1.822-3.662-3.766-4.955-6.037l-.006-.004c-1.294 2.266-2.705 4.213-4.563 6.032a28.48 28.48 0 0 1-19.947 8.125c-7.748 0-14.778-3.11-19.906-8.123a28.025 28.025 0 0 1-4.78-6.155 27.99 27.99 0 0 1-4.736 6.155 28.49 28.49 0 0 1-19.95 8.124c-.27 0-.54-.012-.81-.02h-.007c-.27.008-.54.02-.813.02a28.49 28.49 0 0 1-19.95-8.123 27.992 27.992 0 0 1-4.736-6.155zm-20.486 26.49l-.002.01h.015c8.113.017 15.32 0 24.25 9.746 7.028-.737 14.372-1.105 21.722-1.094h.006c7.35-.01 14.694.357 21.723 1.094 8.93-9.747 16.137-9.73 24.25-9.746h.014l-.002-.01c3.833 0 19.166 0 29.85 30.007L210 165.244c8.504 30.624-2.723 31.373-16.727 31.4-20.768-.773-32.267-15.855-32.267-30.935-11.496 1.884-24.907 2.826-38.318 2.827h-.006c-13.412 0-26.823-.943-38.318-2.827 0 15.08-11.5 30.162-32.267 30.935-14.004-.027-25.23-.775-16.726-31.4L46.85 124.08c10.684-30.007 26.017-30.007 29.85-30.007zm45.985 23.582v.006c-.02.02-21.863 20.08-25.79 27.215l14.304-.573v12.474c0 .584 5.74.346 11.486.08h.006c5.744.266 11.485.504 11.485-.08v-12.474l14.304.573c-3.928-7.135-25.79-27.215-25.79-27.215v-.006l-.003.002z"
							/>
						</svg>
					</Label>
				</div>
			</div>
		</section>

		<Section title='About'>
			<p class='text-muted-foreground'>
				My focus is on building practical applications and interactive systems, with a growing interest in Unreal Engine gameplay programming, state machines, and game-feel experiments.
			</p>
		</Section>

		<Section title='Work Experience'>
			<Card
				as='a'
				heading='Valenin IT Services'
				subheading='DeveOps Intern'
				date='March 2025 - April 2025'
				imagePath='/src/assets/logo-valenin.png'
				altText='faith logo'
				imageClass='h-12 w-auto md:-left-16'
				href='/blog/valenin-devops-intern/'
			>
			</Card>
			<Card
				as='a'
				heading='FAITH College of Computing and Information Technology'
				subheading='Machine Learning Research Analyst Intern'
				date='June 2024 - July 2024'
				imagePath='/src/assets/logo-faith.png'
				altText='faith logo'
				imageClass='h-12 w-auto md:-left-16'
				href='/blog/ccit-ml-intern/'
			>
			</Card>
		</Section>

		<!-- Education Section -->
		<Section title='Education'>
			<Card
				heading='First Asia Institute of Technology and Humanities'
				subheading='B.S. of Computer Science'
				date='2021 - 2025'
				imagePath='/src/assets/logo-faith.png'
				altText='faith logo'
				imageClass='h-12 w-auto md:-left-16'
			>
				<ul class='ml-4 list-disc text-muted-foreground'>
					
					<li><strong>Coursework: </strong> Data Structures, Algorithms, Software Development, Web Development, Machine Learning, and Data Science</li>
				</ul>
			</Card>
		</Section>

		<!-- Project Section -->
		<div>
			<h2 class="mb-6 text-xl font-semibold">Projects & Tech Demos</h2>
			<div class="flex flex-wrap justify-between gap-2">
				<ProjectCard
					as="a"
					href="https://www.youtube.com/watch?v=GM9mxHKBZeA"
					heading="Gravity-Reversal Gameplay Prototype"
					subheading="Surface traversal tech demo"
					imagePath="https://img.youtube.com/vi/GM9mxHKBZeA/maxresdefault.jpg"
					altText="Anti-gravity traversal demo thumbnail"
					skills={gameDevSkills}
					class="w-full sm:w-[48%]"
				/>
				<ProjectCard
					as="a"
					href="https://www.youtube.com/watch?v=eDnOvezfTVc"
					heading="Action Combo System Prototype"
					subheading="State machine combat flow"
					imagePath="https://img.youtube.com/vi/eDnOvezfTVc/maxresdefault.jpg"
					altText="Combo state machine prototype thumbnail"
					skills={gameDevSkills}
					class="w-full sm:w-[48%]"
				/>
				<ProjectCard
					href="https://t.me/solcrack_bot"
					heading="Solana Wallet Tracker"
					subheading=""
					imagePath="/src/assets/project-solcrack.png"
					altText="wallet tracker"
					skills={crypto_web3}
					class="w-full sm:w-[48%]"
				/>
				<ProjectCard
					href="https://barkley.streamlit.app/"
					heading="Tree Bark Image Classification"
					subheading=""
					imagePath="/src/assets/project-barkley.png"
					altText="barkley"
					skills={barkley}
					class="w-full sm:w-[48%]"
				/>
				<ProjectCard
					href="https://trees.firstasia.edu.ph/"
					heading="Leaf Image Classification"
					subheading=""
					imagePath="/src/assets/project-snapfolia.png"
					altText="snapfolia"
					skills={snapfolia}
					class="w-full sm:w-[48%]"
				/>
				<ProjectCard
					as="a"
					href="https://github.com/Alyzbane/Semanticlip"
					heading="Semantic Image Search"
					subheading=""
					imagePath="/src/assets/project-semanticlip.png"
					altText="semanticlip"
					skills={semanticlip}
					class="w-full sm:w-[48%]"
				/>
				<ProjectCard
					as="a"
					href="https://github.com/Alyzbane/Agila"
					heading="Resident Registry System"
					subheading=""
					imagePath="/src/assets/project-agila.png"
					altText="Resident registry system"
					skills={citizenRegistry}
					class="w-full sm:w-[48%]"
				/>
				<ProjectCard
					as="a"
					href="https://github.com/Alyzbane/Alamat-Inventory"
					heading="Library Inventory System"
					subheading=""
					imagePath="/src/assets/project-alamat.png"
					altText="Library Inventory"
					skills={alamat}
					class="w-full sm:w-[48%]"
				/>
			</div>
		</div>
		  
		<!-- Skills Section -->
		<Section title='Skills'>
			<SkillLayout title='Game Development' skills={gameDevSkills} />
			<SkillLayout title='Software Development' skills={softwareDevSkills} />
			<SkillLayout title='AI & ML' skills={mlTech} />
			<SkillLayout title='Tools' skills={devTools} />
		</Section>

		<Section title='Certifications'>
			<Card
				as='a'
				heading='GitHub Foundations'
				subheading='GitHub Foundations Certification Program'
				date='June 2025'
				imagePath='/src/assets/logo-ghf.png'
				altText='Github Foundations certificate'
				imageClass='h-11 w-auto md:-left-16'
				href='https://www.credly.com/badges/8a0f1206-4867-4767-9340-2fd2bfffc260/public_url'
			/>
			<Card
				as='a'
				heading='CompTIA ITF+'
				subheading='CompTIA Information Technology Fundamentals'
				date='May 2024'
				imagePath='/src/assets/logo-itf.png'
				altText='CompTIA ITF+ certificate'
				imageClass='h-11 w-auto md:-left-16'
				href='https://www.credly.com/badges/5129198c-2fb8-40ad-ab95-27908a381327/public_url'
			/>
		</Section>
	</div>
</PageLayout>
