---
import Button from './Button.astro'
import { Image } from 'astro:assets'
import type { ImageMetadata } from 'astro'
import { cn } from '@/utils'

const {
	as: Tag = 'a',
	class: className,
	href,
	heading,
	subheading,
	imagePath,
	altText,
	skills = []
} = Astro.props
const images = import.meta.glob<{ default: ImageMetadata }>('/src/assets/*.{jpeg,jpg,png,gif}')
const image = imagePath && images[imagePath] ? images[imagePath]() : undefined
const isExternalImage = typeof imagePath === 'string' && /^https?:\/\//.test(imagePath)
---

<Tag
	target='_blank'
	class={cn(
		className,
		'flex flex-col gap-y-3 rounded-2xl border border-border bg-primary-foreground ',
		href && 'transition-all hover:border-foreground/25 hover:shadow-sm'
	)}
	href={href}
>
	{image && !isExternalImage && (
		<Image
			src={image}
			alt={altText}
			class='h-48 w-full rounded-2xl rounded-bl-none rounded-br-none object-cover'
			loading='lazy'
		/>
	)}
	{isExternalImage && (
		<img
			src={imagePath}
			alt={altText}
			class='h-48 w-full rounded-2xl rounded-bl-none rounded-br-none object-cover'
			loading='lazy'
		/>
	)}
	<div class='flex flex-col gap-y-0.5 px-5 py-1'>
		<h1 class='text-lg font-medium'>{heading}</h1>
		<h2 class='text-muted-foreground'>{subheading}</h2>
	</div>
	
	<!-- Skills section -->
	<div class="flex flex-wrap gap-2 px-5 pb-4">
		{skills.map((skill: string) => (
			<Button as="button" title={skill} style="pill" />
		))}
	</div>
	
	<slot />
</Tag>
